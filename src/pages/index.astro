---
import '../global.css';

import BrandLogos from '../components/BrandLogos.jsx';
import Hero from '../components/Hero.jsx';
import EventSection from '../components/EventSection.jsx';
import ProgramSection from '../components/ProgramSection.jsx';
import PackagesSection from '../components/PackagesSection.jsx';
import MarketsAndSectors from '../components/MarketsAndSectors.jsx';
import StepsSection from '../components/StepsSection.jsx';
import TrackRecord from '../components/TrackRecord.jsx';
import ApplicationForm from '../components/ApplicationForm.jsx';
import FinalCTA from '../components/FinalCTA.jsx';
import Footer from '../components/Footer.jsx';

import { expoData } from '../data/expoData';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{expoData.event.name} {expoData.event.year}</title>
  </head>

  <body id="top">

    <header class="top-nav" id="home">
      <div class="container">
        <BrandLogos client:idle />
      </div>
    </header>

    <section id="hero">
      <Hero client:idle />
    </section>

    <section id="event">
      <EventSection event={expoData.event} client:idle />
    </section>

    <section id="program">
      <ProgramSection program={expoData.program} client:idle />
    </section>

    <section id="packages">
      <PackagesSection packages={expoData.packages} client:idle />
    </section>

    <section id="markets">
      <MarketsAndSectors
        buyerProfiles={expoData.buyerProfiles}
        sectors={expoData.sectors}
        client:idle
      />
    </section>

    <section id="steps">
      <StepsSection steps={expoData.steps} client:idle />
    </section>

    <section id="track-record">
      <TrackRecord trackRecord={expoData.trackRecord} client:idle />
    </section>

    <section id="apply">
      <ApplicationForm packages={expoData.packages} client:load />
    </section>

    <section id="final-cta">
      <FinalCTA event={expoData.event} client:idle />
    </section>

    <footer id="footer">
      <Footer client:idle />
    </footer>

  </body>
</html>